            },
            "url": {
              "raw": "http://localhost:9090/api/v1/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "9090",
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
