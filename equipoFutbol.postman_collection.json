    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\",\n  \"rol\": 0\n}"
            },
            "url": {
              "raw": "http://localhost:9090/api/v1/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "9090",
              "path": ["api", "v1", "auth", "register"]
            }
          }
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
